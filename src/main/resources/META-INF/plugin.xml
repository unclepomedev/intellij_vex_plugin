<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.unclepomedev.houdinivexassist</id>
    <name>HoudiniVexAssist</name>
    <vendor>unclepomedev</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.unclepomedev.houdinivexassist.settings.VexSettingsState"/>
        <applicationConfigurable parentId="tools" instance="com.github.unclepomedev.houdinivexassist.settings.VexSettingsConfigurable"
                                 id="com.github.unclepomedev.houdinivexassist.settings.VexSettingsConfigurable"
                                 key="vex.settings.display.name"/>
        <fileType name="VEX File" implementationClass="com.github.unclepomedev.houdinivexassist.lang.VexFileType"
                  fieldName="INSTANCE" language="VEX" extensions="vfl;vex"/>

        <lang.parserDefinition language="VEX"
                               implementationClass="com.github.unclepomedev.houdinivexassist.parser.VexParserDefinition"/>
        <lang.syntaxHighlighterFactory language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.highlighting.VexSyntaxHighlighterFactory"/>
        <lang.braceMatcher language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.editor.VexBraceMatcher"/>
        <lang.quoteHandler language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.editor.VexQuoteHandler"/>
        <codeInsight.inlayProvider language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.editor.VexInlayHintsProvider"/>
        <completion.contributor language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.completion.VexCompletionContributor"/>
        <lang.documentationProvider language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.documentation.VexDocumentationProvider"/>
        <lang.formatter language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.formatting.VexFormattingModelBuilder"/>
        <postFormatProcessor implementation="com.github.unclepomedev.houdinivexassist.formatting.VexTrailingNewlinePostFormatProcessor"/>
        <annotator language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.highlighting.VexHighlightingAnnotator"/>
        <annotator language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.highlighting.VexReferenceAnnotator"/>
        <annotator language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.highlighting.VexDeclarationAnnotator"/>
        <annotator language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.highlighting.VexUnusedSymbolAnnotator"/>
        <annotator language="VEX" implementationClass="com.github.unclepomedev.houdinivexassist.highlighting.VexTypeCheckAnnotator"/>

        <fileTemplateGroup implementation="com.github.unclepomedev.houdinivexassist.actions.VexFileTemplateFactory"/>
        <internalFileTemplate name="VexFile"/>
        <internalFileTemplate name="VexFile"/>
    </extensions>
    <actions>
        <action id="Vex.NewFile" class="com.github.unclepomedev.houdinivexassist.actions.CreateVexFileAction">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
        </action>
    </actions>
</idea-plugin>
